# Copy to .env.local and fill values. Live integrations are gated by ENABLE_LIVE_INTEGRATIONS=true.
#
# --- Vercel (deployment) ---
# 1) Import this Git repo in the Vercel dashboard and pick the Next.js preset.
# 2) Set Environment Variables for Production and Preview from this file (Preview may use a
#    staging PostHog project or omit secrets if previews should stay mock-only).
# 3) After first deploy, run the checks in docs/verification-runbook.md against the preview URL.
#
# --- Formbricks (optional contact embed) ---
# When set, /contact shows an iframe above the JSON contact form.
# NEXT_PUBLIC_FORMBRICKS_SURVEY_URL=

# Feature flag — set to "true" to call Resend, Loops, n8n, PostHog capture API, Supabase from API routes
ENABLE_LIVE_INTEGRATIONS=

# Supabase (tool completion logging)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=jacob@darlingmartech.com

# Loops (marketing email / tool leads)
LOOPS_API_KEY=

# PostHog (client SDK + server capture)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# n8n webhooks
N8N_WEBHOOK_URL_CONTACT=
N8N_WEBHOOK_URL_TOOL=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

CAL_OAUTH_SCOPE=read_bookings read_availability read_event_types

# Plausible (privacy-first analytics script)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=darlingmartech.com

# Homepage newsletter band — optional subscriber count token (e.g. 850+ or 1.2k). Shown as "Join {value} readers on the list".
# NEXT_PUBLIC_NEWSLETTER_SUBSCRIBERS=

# Optional — stock search (server-only; use from src/lib/unsplash.ts & src/lib/pexels.ts)
# Never prefix with NEXT_PUBLIC_. Respect each provider's rate limits and attribution rules.
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# --- Phase 4 staging smoke (set ENABLE_LIVE_INTEGRATIONS=true in .env.local) ---
# 1) Contact: POST /api/contact with JSON { "name", "email", "message" } — expect 200; confirm Resend inbox + n8n contact workflow (Twenty CRM is wired inside n8n, not from this repo).
# 2) Tool complete: finish any /tools/[slug] flow — browser calls /api/tool-complete; confirm PostHog event, Supabase row, n8n tool webhook payload.
# 3) Subscribe: submit tool email gate — POST /api/subscribe; confirm Loops contact + Resend tool result email.
# 4) Fix any 502 with "warnings" array: missing or invalid keys for the step that failed.
